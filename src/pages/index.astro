---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import BackToTop from '../components/BackToTop.astro';

const base = import.meta.env.BASE_URL;

const notes = (await getCollection('notes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const latestNotes = notes.slice(0, 5);

const catMap = new Map<string, number>();
for (const note of notes) {
	const cat = note.data.category;
	catMap.set(cat, (catMap.get(cat) || 0) + 1);
}
const categories = [...catMap.entries()]
	.map(([name, count]) => ({ name, count }))
	.sort((a, b) => b.count - a.count);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home-page {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.hero {
				text-align: center;
				margin-bottom: 3rem;
				position: relative;
				overflow: hidden;
				border-radius: 24px;
				padding: 4rem 1.5rem 3rem;
				background: linear-gradient(135deg, rgba(35, 55, 255, 0.04), rgba(0, 204, 255, 0.04));
			}
			:root.dark .hero {
				background: linear-gradient(135deg, rgba(88, 166, 255, 0.06), rgba(165, 214, 255, 0.03));
			}
			.hero-gradient-bg {
				position: absolute;
				inset: -20%;
				background: linear-gradient(-45deg, #2337ff, #0066ff, #00ccff, #00ff88, #2337ff);
				background-size: 400% 400%;
				animation: gradientShift 20s ease infinite;
				opacity: 0.12;
				z-index: 0;
				filter: blur(60px);
			}
			:root.dark .hero-gradient-bg {
				opacity: 0.08;
				background: linear-gradient(-45deg, #58a6ff, #79b8ff, #a5d6ff, #3fb950, #58a6ff);
			}
			.particles-container {
				position: absolute;
				inset: 0;
				top: -2rem;
				left: 0;
				width: 100%;
				height: 200px;
				pointer-events: none;
				z-index: 1;
			}
			.hero > * {
				position: relative;
				z-index: 2;
			}
			.hero-subtitle {
				font-size: 0.75em;
				letter-spacing: 0.15em;
				text-transform: uppercase;
				color: rgb(var(--gray));
				margin-bottom: 0.5rem;
				font-weight: 500;
			}
			.hero h1 {
				margin-bottom: 0.75rem;
			}
			.hero-desc {
				font-size: 1.1em;
				color: rgb(var(--gray));
				max-width: 500px;
				margin: 0 auto 1.5rem;
				line-height: 1.6;
			}
			.hero-links {
				margin-top: 0;
				display: flex;
				justify-content: center;
				gap: 1rem;
				flex-wrap: wrap;
			}
			.cat-links {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.75rem;
				max-width: 640px;
				margin: 0 auto 2rem;
			}
			.cat-links a {
				padding: 0.5em 1.2em;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border-radius: 8px;
				text-decoration: none;
				font-weight: 500;
				font-size: 0.9em;
				transition: all 0.2s;
			}
			.cat-links a:hover {
				background: var(--accent);
				color: white;
			}
			.section-title {
				text-align: center;
				margin: 2rem 0 1.5rem;
			}
			.section-title h2 {
				font-size: 1.6em;
				margin-bottom: 0.25rem;
			}
			.section-title a {
				font-size: 0.9em;
				color: var(--accent);
				text-decoration: none;
			}
			.latest-list {
				list-style: none;
				padding: 0;
				max-width: 640px;
				margin: 0 auto;
			}
			.latest-list li {
				padding: 0.75rem 0;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.latest-list li:last-child {
				border-bottom: none;
			}
			.latest-list a {
				font-weight: 500;
				color: rgb(var(--black));
				text-decoration: none;
				font-size: 1.05em;
			}
			.latest-list a:hover {
				color: var(--accent);
			}
			.latest-list .meta {
				font-size: 0.8em;
				color: rgb(var(--gray));
				margin-top: 0.15rem;
			}

			@media (max-width: 720px) {
				.home-page { padding: 2em 0.75em; }
				.hero { margin-bottom: 2rem; padding: 3rem 1rem 2rem; }
				.hero h1 { font-size: 1.8em; }
				.hero-desc { font-size: 1em; }
				.hero-links { gap: 0.5rem; }
				.hero-cta { padding: 0.5em 1.2em; font-size: 0.9em; }
				.cat-links { gap: 0.4rem; }
				.cat-links a { padding: 0.35em 0.8em; font-size: 0.8em; }
				.section-title h2 { font-size: 1.3em; }
			}
			@media (max-width: 480px) {
				.home-page { padding: 1.5em 0.5em; }
				.hero { padding: 2rem 0.75rem 1.5rem; }
				.hero h1 { font-size: 1.5em; }
				.hero-desc { font-size: 0.9em; margin-bottom: 1rem; }
				.hero-cta { padding: 0.45em 1em; font-size: 0.85em; }
				.section-title { margin: 1.5rem 0 1rem; }
				.section-title h2 { font-size: 1.15em; }
				.latest-list a { font-size: 0.95em; }
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="home-page">
			<section class="hero">
				<div class="hero-gradient-bg"></div>
				<div id="particles-container" class="particles-container"></div>
				<p class="hero-subtitle hero-fade-1">PERSONAL NOTES AND LEARNING JOURNAL</p>
				<h1 class="hero-title gradient-heading hero-fade-2">👋 Lesedi's Notes</h1>
				<p class="hero-desc hero-fade-3">{SITE_DESCRIPTION}</p>
				<div class="hero-links">
					<a href={`${base}notes`} class="hero-cta primary hero-fade-4">📝 浏览笔记</a>
					<a href={`${base}tags`} class="hero-cta secondary hero-fade-5">🏷️ 按标签查看</a>
				</div>
			</section>

			<div class="section-title">
				<h2>分类浏览</h2>
			</div>
			<div class="cat-links">
				{categories.map((cat) => (
					<a href={`${base}notes?category=${encodeURIComponent(cat.name)}`}>
						{cat.name} <span style="font-size:0.7em;opacity:0.7;margin-left:0.3em;">{cat.count}</span>
					</a>
				))}
			</div>

			<div class="section-title">
				<h2>最新笔记</h2>
				<a href={`${base}notes`}>查看全部 →</a>
			</div>
			<ul class="latest-list">
				{latestNotes.map((note) => (
					<li>
						<a href={`${base}notes/${note.id}/`}>{note.data.title}</a>
						<div class="meta">
							<FormattedDate date={note.data.pubDate} />
							{' · '}
							{note.data.tags.slice(0, 3).join(', ')}
						</div>
					</li>
				))}
			</ul>
		</main>
		<Footer />
		<BackToTop />
	</body>

		<script is:inline>
			// Custom cursor
			(function initCursor() {
				var isTouch = window.matchMedia('(pointer: coarse)').matches;
				if (isTouch) return;
				var cursor = document.createElement('div');
				cursor.id = 'custom-cursor';
				cursor.setAttribute('aria-hidden', 'true');
				document.body.appendChild(cursor);
				var mouseX = 0, mouseY = 0, cx = 0, cy = 0, hovering = false;
				document.addEventListener('mousemove', function(e) { mouseX = e.clientX; mouseY = e.clientY; });
				document.addEventListener('mouseover', function(e) { if (e.target.closest('a,button,.note-card')) { hovering = true; cursor.classList.add('hovering'); } });
				document.addEventListener('mouseout', function(e) { if (e.target.closest('a,button,.note-card')) { hovering = false; cursor.classList.remove('hovering'); } });
				(function animate() { cx += (mouseX - cx) * 0.15; cy += (mouseY - cy) * 0.15; cursor.style.transform = 'translate3d(' + (cx - 12) + 'px,' + (cy - 12) + 'px,0)'; requestAnimationFrame(animate); })();
			})();

			// Hero fade-up is handled by CSS keyframes (no JS needed)

			// Animate category links
			(function initCatAnims() {
				var links = document.querySelectorAll('.cat-links a');
				if ('IntersectionObserver' in window) {
					var obs = new IntersectionObserver(function(entries) {
						entries.forEach(function(entry) {
							if (entry.isIntersecting) {
								entry.target.classList.add('visible');
								obs.unobserve(entry.target);
							}
						});
					}, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
					links.forEach(function(el, i) {
						el.classList.add('animate-on-scroll');
						var delay = ((i % 6) * 80) + 'ms';
						el.style.setProperty('--stagger-delay', delay);
						obs.observe(el);
					});
				} else {
					links.forEach(function(el) { el.classList.add('visible'); });
				}
			})();

			// Animate latest list items
			(function initListAnims() {
				var items = document.querySelectorAll('.latest-list li');
				if ('IntersectionObserver' in window) {
					var obs = new IntersectionObserver(function(entries) {
						entries.forEach(function(entry) {
							if (entry.isIntersecting) {
								entry.target.classList.add('visible');
								obs.unobserve(entry.target);
							}
						});
					}, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
					items.forEach(function(el, i) {
						el.classList.add('animate-on-scroll');
						var delay = ((i % 6) * 80) + 'ms';
						el.style.setProperty('--stagger-delay', delay);
						obs.observe(el);
					});
				} else {
					items.forEach(function(el) { el.classList.add('visible'); });
				}
			})();

			// Magnetic buttons for hero CTAs
			(function initMagnetic() {
				var isTouch = window.matchMedia('(pointer: coarse)').matches;
				if (isTouch) return;
				var btns = document.querySelectorAll('.hero-cta');
				btns.forEach(function(btn) {
					var strength = 0.3;
					var radius = 80;
					var tx = 0, ty = 0, cx = 0, cy = 0, rafId = 0;
					btn.addEventListener('mousemove', function(e) {
						var rect = btn.getBoundingClientRect();
						var mx = e.clientX - (rect.left + rect.width / 2);
						var my = e.clientY - (rect.top + rect.height / 2);
						var dist = Math.sqrt(mx * mx + my * my);
						tx = dist < radius ? mx * strength : 0;
						ty = dist < radius ? my * strength : 0;
					});
					function animate() {
						cx += (tx - cx) * 0.1;
						cy += (ty - cy) * 0.1;
						btn.style.transform = 'translate(' + cx + 'px,' + cy + 'px)';
						if (Math.abs(tx - cx) > 0.1 || Math.abs(ty - cy) > 0.1) {
							rafId = requestAnimationFrame(animate);
						}
					}
					btn.addEventListener('mouseenter', function() {
						if (rafId) cancelAnimationFrame(rafId);
						animate();
					});
					btn.addEventListener('mouseleave', function() {
						if (rafId) cancelAnimationFrame(rafId);
						rafId = 0; tx = 0; ty = 0; cx = 0; cy = 0;
						btn.style.transform = '';
					});
				});
			})();

			// Particle background
			(function initParticles() {
				var container = document.getElementById('particles-container');
				if (!container) return;
				var canvas = document.createElement('canvas');
				container.appendChild(canvas);
				var ctx = canvas.getContext('2d');
				var particles = [];
				var count = 40;
				var w, h;

				function resize() {
					var rect = container.getBoundingClientRect();
					w = canvas.width = rect.width;
					h = canvas.height = rect.height;
				}
				resize();
				window.addEventListener('resize', resize);

				function createParticle() {
					return {
						x: Math.random() * w,
						y: Math.random() * h,
						r: Math.random() * 2 + 1,
						dx: (Math.random() - 0.5) * 0.5,
						dy: (Math.random() - 0.5) * 0.5,
						opacity: Math.random() * 0.5 + 0.2
					};
				}

				for (var i = 0; i < count; i++) {
					particles.push(createParticle());
				}

				function draw() {
					ctx.clearRect(0, 0, w, h);
					for (var j = 0; j < particles.length; j++) {
						var p = particles[j];
						ctx.beginPath();
						ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
						ctx.fillStyle = 'rgba(35, 55, 255, ' + p.opacity + ')';
						ctx.fill();
					}
					// Draw connections
					for (var a = 0; a < particles.length; a++) {
						for (var b = a + 1; b < particles.length; b++) {
							var dx = particles[a].x - particles[b].x;
							var dy = particles[a].y - particles[b].y;
							var dist = Math.sqrt(dx * dx + dy * dy);
							if (dist < 120) {
								ctx.beginPath();
								ctx.moveTo(particles[a].x, particles[a].y);
								ctx.lineTo(particles[b].x, particles[b].y);
								ctx.strokeStyle = 'rgba(35, 55, 255, ' + (1 - dist / 120) * 0.15 + ')';
								ctx.lineWidth = 1;
								ctx.stroke();
							}
						}
					}
				}

				function update() {
					for (var i = 0; i < particles.length; i++) {
						var p = particles[i];
						p.x += p.dx;
						p.y += p.dy;
						if (p.x < 0 || p.x > w) p.dx *= -1;
						if (p.y < 0 || p.y > h) p.dy *= -1;
					}
				}

				function animate() {
					update();
					draw();
					requestAnimationFrame(animate);
				}
				animate();
			})();
		</script>
	</html>
