---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import NoteCard from '../../components/NoteCard.astro';
import { SITE_TITLE } from '../../consts';

const allNotes = (await getCollection('notes')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Collect categories and their counts + tags
const catMap = new Map<string, { count: number; tags: Map<string, number> }>();
for (const note of allNotes) {
	const cat = note.data.category;
	if (!catMap.has(cat)) {
		catMap.set(cat, { count: 0, tags: new Map() });
	}
	const entry = catMap.get(cat)!;
	entry.count++;
	for (const tag of note.data.tags) {
		entry.tags.set(tag, (entry.tags.get(tag) || 0) + 1);
	}
}

const categories = [...catMap.entries()].map(([name, data]) => ({
	name,
	count: data.count,
	tags: [...data.tags.entries()].map(([n, c]) => ({ name: n, count: c })),
}));

const pageTitle = '笔记';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`${pageTitle} | ${SITE_TITLE}`} description={`${allNotes.length} 篇笔记，${categories.length} 个分类`} />
		<style>
			.notes-page {
				width: 960px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.notes-header {
				margin-bottom: 1.5rem;
				text-align: center;
			}
			.notes-header h1 {
				margin-bottom: 0.25rem;
			}
			.notes-header p {
				color: rgb(var(--gray));
				font-size: 1.1em;
			}
			.cat-filters {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.5rem;
				margin-bottom: 1rem;
			}
			.cat-filter-btn {
				padding: 0.4em 1em;
				font-size: 0.9em;
				font-family: inherit;
				font-weight: 500;
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				border: 2px solid transparent;
				border-radius: 8px;
				cursor: pointer;
				transition: all 0.2s;
			}
			.cat-filter-btn:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.cat-filter-btn.active {
				background: var(--accent);
				color: white;
				border-color: var(--accent);
			}
			.sub-tags {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				gap: 0.35rem;
				margin-bottom: 2rem;
				padding: 0.75rem;
				background: rgb(var(--gray-light));
				border-radius: 8px;
				min-height: 1em;
			}
			.sub-tag-btn {
				padding: 0.15em 0.65em;
				font-size: 0.78em;
				font-family: inherit;
				background: white;
				color: rgb(var(--gray-dark));
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				cursor: pointer;
				transition: all 0.2s;
			}
			.sub-tag-btn:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.sub-tag-btn.active {
				background: var(--accent-dark);
				color: white;
				border-color: var(--accent-dark);
			}
			.notes-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="notes-page">
			<header class="notes-header">
				<h1>📝 笔记</h1>
				<p>{allNotes.length} 篇笔记 · {categories.length} 个分类</p>
			</header>

			<span id="cat-data" style="display:none" data-categories={JSON.stringify(categories.map(c => ({ name: c.name, tags: c.tags })))}></span>
			<div class="cat-filters" id="cat-filters">
				<button class="cat-filter-btn active" data-cat="">全部</button>
				{categories.map((cat) => (
					<button class="cat-filter-btn" data-cat={cat.name}>
						{cat.name} ({cat.count})
					</button>
				))}
			</div>

			<div class="sub-tags" id="sub-tags"></div>

			<div class="notes-grid" id="notes-grid">
				{allNotes.map((note) => (
					<div class="note-item" data-category={note.data.category} data-tags={JSON.stringify(note.data.tags)}>
						<NoteCard note={note} />
					</div>
				))}
			</div>
		</main>
		<Footer />

		<script>
			const CATEGORIES = JSON.parse(document.getElementById('cat-data')!.dataset.categories || '[]');
			const catBtns = document.querySelectorAll('.cat-filter-btn');
			const subTagsDiv = document.getElementById('sub-tags')!;
			const noteItems = document.querySelectorAll('.note-item');

			const params = new URLSearchParams(window.location.search);
			const initCat = params.get('category') || '';
			const initTag = params.get('tag') || '';

			function getSubTags(catName) {
				const cat = CATEGORIES.find((c) => c.name === catName);
				return cat ? cat.tags : [];
			}

			function renderSubTags(catName, activeTag) {
				if (!catName) { subTagsDiv.innerHTML = ''; return; }
				const subTags = getSubTags(catName);
				let html = `<button class="sub-tag-btn${!activeTag ? ' active' : ''}" data-tag="">全部</button>`;
				for (const t of subTags) {
					html += `<button class="sub-tag-btn${t.name === activeTag ? ' active' : ''}" data-tag="${t.name}">${t.name} (${t.count})</button>`;
				}
				subTagsDiv.innerHTML = html;

				subTagsDiv.querySelectorAll('.sub-tag-btn').forEach(btn => {
					btn.addEventListener('click', () => {
						const tag = btn.getAttribute('data-tag') || '';
						filterAll(catName, tag);
						updateUrl(catName, tag);
					});
				});
			}

			function filterAll(cat, tag) {
				noteItems.forEach((item) => {
					const el = item;
					const itemCat = el.dataset.category || '';
					const itemTags = JSON.parse(el.dataset.tags || '[]');

					let show = true;
					if (cat && itemCat !== cat) show = false;
					if (tag && !itemTags.includes(tag)) show = false;

					el.style.display = show ? '' : 'none';
				});

				catBtns.forEach((btn) => {
					btn.classList.toggle('active', btn.getAttribute('data-cat') === cat);
				});

				renderSubTags(cat, tag);
			}

			function updateUrl(cat, tag) {
				const url = new URL(window.location.href);
				if (cat) url.searchParams.set('category', cat);
				else url.searchParams.delete('category');
				if (tag) url.searchParams.set('tag', tag);
				else url.searchParams.delete('tag');
				window.history.replaceState({}, '', url.toString());
			}

			// Init
			filterAll(initCat, initTag);

			catBtns.forEach((btn) => {
				btn.addEventListener('click', () => {
					const cat = btn.getAttribute('data-cat') || '';
					filterAll(cat, '');
					updateUrl(cat, '');
				});
			});
		</script>
	</body>
</html>

<style>
	@media (max-width: 720px) {
		.notes-page { padding: 2em 0.75em; }
		.notes-header h1 { font-size: 1.8em; }
		.cat-filter-btn { padding: 0.3em 0.7em; font-size: 0.8em; }
		.sub-tags { padding: 0.5em; gap: 0.3rem; }
		.sub-tag-btn { font-size: 0.72em; padding: 0.12em 0.5em; }
		.notes-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; }
	}
	@media (max-width: 480px) {
		.notes-page { padding: 1.5em 0.5em; }
		.notes-header h1 { font-size: 1.4em; }
		.notes-header p { font-size: 0.9em; }
		.cat-filters { gap: 0.3rem; }
		.cat-filter-btn { padding: 0.25em 0.6em; font-size: 0.75em; border-radius: 6px; }
		.sub-tags { padding: 0.4em; }
		.sub-tag-btn { font-size: 0.68em; }
		.notes-grid { grid-template-columns: 1fr; gap: 0.75rem; }
	}
</style>
